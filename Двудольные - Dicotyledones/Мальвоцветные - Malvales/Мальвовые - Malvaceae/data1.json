4%D1%80%D0%B5%D0%B2%D0%BE%D0%B2%D0%B8%D0%B4%D0%BD%D1%8B%D0%B8%20-%20Gossypium%20arboreum","deepCounters":{"total":7,"images":7,"files":7},"counters":{"total":7,"images":7,"files":7},"thumb":{"path":"%D0%A5%D0%BB%D0%BE%D0%BF%D1%87%D0%B0%D1%82%D0%BD%D0%B8%D0%BA%20%D0%B4%D1%80%D0%B5%D0%B2%D0%BE%D0%B2%D0%B8%D0%B4%D0%BD%D1%8B%D0%B8%20-%20Gossypium%20arboreum\/thumbs\/DSC05509.jpg","width":512,"height":410},"thumbCaption":"<h3>–•–ї–Њ–њ—З–∞—В–љ–Є–Ї –і—А–µ–≤–Њ–≤–Є–і–љ—Л–є - Gossypium arboreum<\/h3>","name":"–•–ї–Њ–њ—З–∞—В–љ–Є–Ї –і—А–µ–≤–Њ–≤–Є–і–љ—Л–Є - Gossypium arboreum","dates":{"added":1630863054,"dateRange":{"0":1356338090,"1":1630853271}},"fileDate":"2023-01-20T18:19:43.779Z","category":"folder","title":"–•–ї–Њ–њ—З–∞—В–љ–Є–Ї –і—А–µ–≤–Њ–≤–Є–і–љ—Л–є - Gossypium arboreum"},{"path":"%D0%A8%D1%82%D0%BE%D0%BA%D1%80%D0%BE%D0%B7%D0%B0%20%D1%80%D0%BE%D0%B7%D0%BE%D0%B2%D0%B0%D1%8F%20-%20Alcea%20rosea","deepCounters":{"total":32,"images":32,"files":32},"counters":{"total":32,"images":32,"files":32},"thumb":{"path":"%D0%A8%D1%82%D0%BE%D0%BA%D1%80%D0%BE%D0%B7%D0%B0%20%D1%80%D0%BE%D0%B7%D0%BE%D0%B2%D0%B0%D1%8F%20-%20Alcea%20rosea\/thumbs\/DSC08738.jpg","width":512,"height":410},"thumbCaption":"<h3>–®—В–Њ–Ї—А–Њ–Ј–∞ —А–Њ–Ј–Њ–≤–∞—П - Alcea rosea<\/h3>","name":"–®—В–Њ–Ї—А–Њ–Ј–∞ —А–Њ–Ј–Њ–≤–∞—П - Alcea rosea","dates":{"added":1658856650,"dateRange":{"0":1278564185,"1":1658737498}},"fileDate":"2023-01-20T18:20:18.559Z","category":"folder"}],"name":"–Ь–∞–ї—М–≤–Њ–≤—Л–µ - Malvaceae","comment":"Malvaceae, or the mallows, is a family of flowering plants estimated to contain 244 genera with 4225 known species. Well-known members of this family include okra, cotton, cacao and durian. The largest genera in terms of number of species include Hibiscus (300 species), Sterculia (250 species), Dombeya (250 species), Pavonia (200 species) and Sida (200 species).\nThe circumscription of the Malvaceae is controversial. The traditional Malvaceae sensu stricto comprise a very homogeneous and cladistically monophyletic group. Another major circumscription, Malvaceae sensu lato, has been more recently defined on the basis that molecular techniques have shown the commonly recognised families Bombacaceae, Tiliaceae, and Sterculiaceae, which have always been considered closely allied to Malvaceae s.s., are not monophyletic groups. Thus, the Malvaceae can be expanded to include all of these families so as to compose a monophyletic group. Adopting this circumscription, the Malvaceae incorporate a much larger number of genera.","dates":{"added":1688936036,"dateRange":{"0":1221071470,"1":1687705461}},"fileDate":"2023-01-20T17:48:47.499Z"}